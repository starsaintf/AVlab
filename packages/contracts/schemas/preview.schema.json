{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://avlab.dev/schemas/preview/0.1",
  "title": "AVlab Preview",
  "type": "object",
  "required": ["schema","previewId","projectId","versionId","mediaKind","mimeType","fileName","relativePath","source","size","contentId","createdAt"],
  "properties": {
    "schema": {"const": "avlab.preview/0.1"},
    "previewId": {"type": "string", "pattern": "^prv_"},
    "projectId": {"type": "string", "pattern": "^avp_"},
    "versionId": {"type": "string", "pattern": "^avv_"},
    "mediaKind": {"enum": ["audio","video","image","unknown"]},
    "mimeType": {"type": "string"},
    "fileName": {"type": "string"},
    "relativePath": {"type": "string"},
    "source": {"enum": ["generated","user-export","host-render","agent-render"]},
    "size": {"type": "integer", "minimum": 0},
    "contentId": {"type": "string", "pattern": "^sha256:[a-f0-9]{64}$"},
    "createdAt": {"type": "string", "format": "date-time"},
    "durationMs": {"type": "number", "minimum": 0},
    "profile": {"enum": ["compact","review","high-quality"]},
    "metadata": {"type":"object","properties":{"durationMs":{"type":"number","minimum":0},"width":{"type":"integer","minimum":1},"height":{"type":"integer","minimum":1},"frameRate":{"type":"number","minimum":0},"sampleRate":{"type":"number","minimum":0},"channels":{"type":"integer","minimum":1},"codec":{"type":"string"},"format":{"type":"string"}},"additionalProperties":false},
    "waveformRelativePath": {"type": "string"},
    "thumbnailRelativePath": {"type": "string"}
  },
  "additionalProperties": false
}
