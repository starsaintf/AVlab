{
  "$schema":"https://json-schema.org/draft/2020-12/schema","$id":"https://avlab.dev/schemas/review/0.1","title":"AVlab Review","type":"object",
  "required":["schema","reviewId","projectId","versionId","title","token","permissions","requiredApprovals","status","createdAt"],
